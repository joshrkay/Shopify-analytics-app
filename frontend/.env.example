# Copy to .env or .env.local in this directory, then restart `npm run dev`.
# Vite only reads env files next to package.json (not the repo-root .env).

# Required — from Clerk Dashboard → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=

# Optional — defaults to same-origin / Vite proxy (e.g. http://localhost:3000 → /api → backend)
# VITE_API_URL=http://localhost:8000

# Optional
# VITE_SENTRY_DSN=
