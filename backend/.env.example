# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# Variables marked [REQUIRED] will cause errors if missing in production.

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/markinsight  # [REQUIRED]

# --- Redis ---
REDIS_URL=redis://localhost:6379/0  # [REQUIRED] Used for caching, OAuth state, queues

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=sk_test_...           # [REQUIRED] Clerk backend secret key
CLERK_FRONTEND_API=https://...clerk.accounts.dev  # [REQUIRED] Clerk frontend API URL
CLERK_WEBHOOK_SECRET=whsec_...         # [REQUIRED] Clerk webhook signing secret
JWT_SECRET=                            # [REQUIRED] Secret for signing agency JWTs — NO default in production

# --- Shopify ---
SHOPIFY_API_KEY=                       # [REQUIRED] Shopify app API key
SHOPIFY_API_SECRET=                    # [REQUIRED] Shopify app API secret
SHOPIFY_BILLING_TEST_MODE=true         # Set to false in production
SHOPIFY_BILLING_RETURN_URL=https://app.example.com/billing/callback

# --- OAuth Platform Credentials ---
META_APP_ID=
META_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://app.example.com/oauth/callback

# --- Superset (Embedded Analytics) ---
SUPERSET_EMBED_URL=http://localhost:8088  # [REQUIRED] Superset base URL
SUPERSET_USERNAME=                        # [REQUIRED] Superset admin username — NO default
SUPERSET_PASSWORD=                        # [REQUIRED] Superset admin password — NO default
SUPERSET_JWT_SECRET=
SUPERSET_SECRET_KEY=

# --- Airbyte (ETL) ---
AIRBYTE_BASE_URL=http://localhost:8000
AIRBYTE_WORKSPACE_ID=
AIRBYTE_API_TOKEN=
AIRBYTE_DESTINATION_ID=

# --- LLM Integration ---
OPENROUTER_API_KEY=                    # [REQUIRED] for AI insights/recommendations

# --- Email Notifications ---
SENDGRID_API_KEY=
NOTIFICATION_EMAIL_PROVIDER=sendgrid

# --- App URLs ---
APP_BASE_URL=https://app.example.com   # [REQUIRED] Base URL for email links
APP_URL=https://app.example.com        # [REQUIRED] Used for billing return URLs

# --- Encryption ---
ENCRYPTION_KEY=                        # [REQUIRED] Base64-encoded key for encrypting secrets
